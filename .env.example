# Copy this file to .env.local and fill in real values.
# Never commit .env.local — .gitignore excludes all .env* files except this one.

# ---- Supabase ----
# Find these in your Supabase project: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose this client-side. Used by API routes to bypass RLS
# for trusted operations (e.g. the price_cache table).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Alpha Vantage ----
# Sign up free at https://www.alphavantage.co/support/#api-key (instant, no card).
# Free tier: 25 calls/day — the /api/quotes route caches aggressively.
ALPHAVANTAGE_API_KEY=your-alpha-vantage-key

# ---- App config ----
# Used for the Origin header CSRF check. In production set this to your domain
# (e.g. https://tracker.example.com). Locally, leave as http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
